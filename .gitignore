# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode build artifacts
build/
DerivedData/
*.xcuserstate
xcuserdata/

# Generated by xcodegen — regenerate with: xcodegen generate
Merlin.xcodeproj/

# Swift Package Manager
.build/
.swiftpm/

# Credentials — never commit
*.p12
*.mobileprovision
api-keys.json
**/api-keys.json
.merlin/api-keys.json
.env
.env.local
dist/
plugins/electronics/*.dylib

# Claude Code workspace files
.claude/

# Project Discipline runtime artifacts — per-machine state, regenerated each run.
# .merlin/project.toml IS tracked (it is config); these are not.
.merlin/pending.json
.merlin/discipline-events.jsonl
.merlin/override-log.jsonl

# Eval suite (merlin-eval/) — fixture *sources* and the OCR image are tracked; the
# regenerable build outputs are not.
merlin-eval/fixtures/**/target/
merlin-eval/fixtures/**/ledger.txt
merlin-eval/fixtures/electronics/*
!merlin-eval/fixtures/electronics/schematic-image/

# schematic-image: source fixtures (ground-truth.json, rc-filter.{kicad_sch,pdf,png})
# are tracked; per-run outputs are not.
merlin-eval/fixtures/electronics/schematic-image/output/
merlin-eval/fixtures/electronics/schematic-image/kicad-project/
merlin-eval/fixtures/electronics/schematic-image/extraction-report.json
merlin-eval/fixtures/electronics/schematic-image/component-matrix.json
merlin-eval/fixtures/electronics/schematic-image/design-intent.json
merlin-eval/fixtures/electronics/schematic-image/rc-filter-preprocessed.png

# Ad-hoc KiCad project working area — per-developer; the eval suite tracks its
# own fixtures under merlin-eval/.
kicad-projects/
